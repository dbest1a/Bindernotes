{
  "name": "binder-notes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest --run",
    "typecheck": "tsc -b --pretty false",
    "seed:system": "tsx scripts/seed-system.ts",
    "repair:system": "tsx scripts/repair-system-content.ts",
    "repair:system:apply": "tsx scripts/repair-system-content.ts --apply",
    "verify:system": "tsx scripts/verify-system-content.ts",
    "verify:system-seed": "tsx scripts/verify-system-seed.ts",
    "seed:math": "tsx scripts/seed-math.ts",
    "verify:math-seed": "tsx scripts/verify-math-seed.ts",
    "cleanup:placeholders": "tsx scripts/cleanup-workspace-placeholders.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.2",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@vitejs/plugin-react": "^5.0.4",
    "bidi-js": "^1.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "vitest": "^4.1.4"
  }
